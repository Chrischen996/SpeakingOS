# Shared
NODE_ENV=development
APP_ORIGIN=http://localhost:3000

# API
API_PORT=3001
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret

# Database
DATABASE_URL=postgresql://speakingos:speakingos@localhost:5432/speakingos?schema=public

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Object storage (local MinIO defaults)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=speakingos-audio
S3_ACCESS_KEY_ID=speakingos
S3_SECRET_ACCESS_KEY=speakingos-secret
S3_FORCE_PATH_STYLE=true

# AI providers (optional until real providers are enabled)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=fake
SPEECH_PROVIDER=fake
